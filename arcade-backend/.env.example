# --- App ---
APP_ENV=development
SECRET_KEY=replace-with-a-long-random-string
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Database ---
# SQLite (default, zero setup):
DATABASE_URL=sqlite:///./arcade.db
# Postgres example (Render auto-injects this):
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname

# --- SMTP (free options: Gmail App Password, Brevo, Mailtrap) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@arcadehub.local
SMTP_TLS=true
# If SMTP isn't configured, emails are logged to console so signup still works.
EMAIL_CONSOLE_FALLBACK=true

# --- Gameplay ---
SIGNUP_BONUS_COINS=500

# --- Admin bootstrap (auto-created on first startup if missing) ---
# CHANGE THESE BEFORE DEPLOYING TO PRODUCTION.
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=admin123
ADMIN_USERNAME=admin
